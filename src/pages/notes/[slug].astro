---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import MarkdownProse from "../../components/MarkdownProse.astro";
import { getPublishedNotes } from "../../lib/notes";

export async function getStaticPaths() {
  const posts = await getPublishedNotes();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = post.data.pubDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
const words = post.body.split(/\s+/).length;
const readMinutes = Math.max(1, Math.round(words / 200));
---

<MainLayout title={post.data.title} description={post.data.description}>
  <article class="section">
    <a class="back-link" href="/notes">← Notes index</a>
    <h1>{post.data.title}</h1>
    <p class="detail-summary">{post.data.description}</p>
    <p class="detail-meta">{date} • {readMinutes} min read</p>
    <MarkdownProse />
    <div class="prose detail-body">
      <Content />
    </div>
  </article>
</MainLayout>
